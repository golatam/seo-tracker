# This file holds SECRETS and a few global knobs only.
#
# Standalone service (recommended): per-project config (SITE_URL, RANK_SOURCE,
# TOPVISOR_PROJECT_ID, NOTIFIER, CORE_PATH, SNAPSHOTS_DIR, …) lives in
# projects/<id>.json and is injected by scripts/check-project.mjs at run time —
# do NOT set those here. The SITE_*/NOTIFIER/RANK_SOURCE/path blocks below are
# only used by the LEGACY direct CLI path (weekly-check.mjs run by hand or by
# the reusable workflow). In standalone mode you can leave them commented out.

# ─── Service paths (standalone mode) ────────────────────────────────
# Where the registry and per-project data live. Default to ./projects and
# ./data relative to the repo root. Override to relocate either.
# PROJECTS_DIR=./projects
# DATA_DIR=./data

# ─── Site identity (LEGACY direct CLI only) ─────────────────────────
# Ignored in standalone mode (the descriptor provides these). For the direct
# weekly-check.mjs / reusable-workflow path:
# SITE_URL — your website origin (no trailing slash)
# SITE_PROPERTY — GSC property identifier:
#   - sc-domain:example.com  (covers all subdomains and protocols)
#   - https://example.com/   (URL-prefix property — exact origin only)
# SITE_NAME — optional; display name in reports. Defaults to SITE_URL hostname.
# SITE_URL=https://example.com
# SITE_PROPERTY=sc-domain:example.com
# SITE_NAME=example.com

# ─── Notifier (LEGACY direct CLI only) ──────────────────────────────
# slack | telegram | both | none. Standalone mode reads this from the descriptor.
# NOTIFIER=telegram

# ─── Rank source (LEGACY direct CLI only) ───────────────────────────
# Where keyword POSITIONS come from. Standalone mode reads this from the
# descriptor's rankSource.
#   topvisor  — Topvisor exact rank tracking (read-only history) — primary
#   gsc       — Google Search Console average position (legacy)
#   mixed     — reserved; currently behaves like gsc
# GSC/Yandex stay the analytics/indexation layer regardless of this value.
# RANK_SOURCE=topvisor

# ─── Feature flags (LEGACY direct CLI only) ─────────────────────────
# Set to "true" to also fetch Yandex.Webmaster positions. Standalone mode reads
# this from the descriptor's enableYandex.
# ENABLE_YANDEX=false

# ─── Paths (LEGACY direct CLI only) ─────────────────────────────────
# Standalone mode derives these per project under DATA_DIR/<id>/.
# CORE_PATH=./semantic-core.json
# SNAPSHOTS_DIR=./snapshots

# ─── Google Search Console API (OAuth2) ─────────────────────────────
# Create credentials at: https://console.cloud.google.com/apis/credentials
# Enable "Google Search Console API" in your project
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# ─── Slack notifications (NOTIFIER=slack|both) ──────────────────────
# Create app at: https://api.slack.com/apps — scope: chat:write
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ─── Telegram notifications (NOTIFIER=telegram|both) ────────────────
# Bot token from @BotFather. Chat ID — negative for channels (-100...)
# TELEGRAM_THREAD_ID is optional; set for group topics.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# TELEGRAM_THREAD_ID=

# ─── Yandex.Webmaster (ENABLE_YANDEX=true) ──────────────────────────
# YANDEX_OAUTH_TOKEN=
# YANDEX_USER_ID=

# ─── Topvisor (RANK_SOURCE=topvisor) ────────────────────────────────
# Read-only rank tracking. Get the API token at:
#   https://topvisor.com → Settings → API
# TOPVISOR_USER_ID            — account user id (sent as User-Id header)
# TOPVISOR_API_TOKEN          — API token (sent as Authorization: bearer ...)
# TOPVISOR_PROJECT_ID         — numeric project id to read positions from
# TOPVISOR_REGIONS_INDEXES    — comma-separated region indexes, e.g. "1,2"
#                               (empty = all regions returned by the project)
# TOPVISOR_DATE_MODE          — lastTwo (default) | single
TOPVISOR_USER_ID=
TOPVISOR_API_TOKEN=
TOPVISOR_PROJECT_ID=
TOPVISOR_REGIONS_INDEXES=
TOPVISOR_DATE_MODE=lastTwo
