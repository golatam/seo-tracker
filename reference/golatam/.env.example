# ──────────────────────────────────────────────────────
# SEO Tracking — Environment Variables
# Скопируйте в .env в корне проекта и заполните значения
# ──────────────────────────────────────────────────────

# ─── Telegram Bot (временно отключён в config.mjs) ───
# 1. Откройте @BotFather в Telegram
# 2. /newbot → дайте имя → получите токен
# 3. Добавьте бота в чат/группу
# 4. Узнайте chat_id: отправьте боту сообщение, затем откройте
#    https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# ─── Slack Bot ───────────────────────────────────────
# 1. https://api.slack.com/apps → Create New App → From scratch
# 2. OAuth & Permissions → Bot Token Scopes → добавьте: chat:write
# 3. Install to Workspace → скопируйте Bot User OAuth Token (xoxb-...)
# 4. Добавьте бота в нужный канал: /invite @BotName
# 5. Channel ID: правый клик по каналу → Copy link → последний сегмент
SLACK_BOT_TOKEN=
SLACK_CHANNEL_ID=

# ─── Google Search Console (OAuth2) ───────────────────
# 1. Перейдите в Google Cloud Console → APIs → Enable "Google Search Console API"
# 2. Credentials → Create OAuth client ID (тип: Web application)
# 3. Добавьте Authorized redirect URI: http://localhost
# 4. Получите код авторизации:
#    https://accounts.google.com/o/oauth2/v2/auth?client_id=<ID>&redirect_uri=http://localhost&response_type=code&scope=https://www.googleapis.com/auth/webmasters.readonly&access_type=offline&prompt=consent
# 5. Обменяйте код на refresh_token через token endpoint
GSC_CLIENT_ID=
GSC_CLIENT_SECRET=
GSC_REFRESH_TOKEN=

# ─── Яндекс.Вебмастер ────────────────────────────────
# 1. Зарегистрируйте приложение: https://oauth.yandex.ru/client/new
#    - Платформа: Веб-сервисы
#    - Права: webmaster:verify, webmaster:hostinfo
#    - Redirect URI: https://oauth.yandex.ru/verification_code
# 2. Получите токен: https://oauth.yandex.ru/authorize?response_type=token&client_id=<CLIENT_ID>
# 3. host_id: вызовите GET https://api.webmaster.yandex.net/v4/user/<user_id>/hosts
#    с заголовком Authorization: OAuth <token>
YANDEX_OAUTH_TOKEN=
YANDEX_USER_ID=
YANDEX_HOST_ID=
